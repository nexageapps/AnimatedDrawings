{
  "name": "ocean",
  "display_name": "Ocean Adventure",
  "background_image_url": "/static/backgrounds/ocean.jpg",
  "dimensions": {
    "width": 1920,
    "height": 1080
  },
  "max_entities": 50,
  "positioning_rules": {
    "type": "depth_layers",
    "min_spacing": 50,
    "layers": [
      {"name": "surface", "y_range": [100, 300], "scale": 0.8},
      {"name": "shallow", "y_range": [300, 600], "scale": 0.9},
      {"name": "deep", "y_range": [600, 900], "scale": 1.0}
    ],
    "floating": true
  },
  "motion_sequences": ["wave_hello", "zombie", "jesse_dance"],
  "description": "An underwater ocean scene with depth-based layers for swimming and floating positions"
}
